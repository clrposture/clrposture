{
  "name": "@clrposture/core",
  "version": "0.1.0",
  "description": "NIST CSF 2.0 assessment engine — question bank, scoring, and gap analysis",
  "license": "MIT",
  "homepage": "https://github.com/clrposture/clrposture-core#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/clrposture/clrposture-core.git",
    "directory": "packages/core"
  },
  "keywords": [
    "nist",
    "csf",
    "cybersecurity",
